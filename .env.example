# Connector-level env for the Twilio MCP shim. Copy to .env (gitignored).
# Per-MCP secrets (TWILIO_*) live in mcp/twilio-mcp-server/.env, NOT here.

# Controller HTTPS root. Used for the register API call. The connector
# internally upgrades https:// → wss:// for the tunnel.
CONTROLLER_URL=https://your-controller.example.com

# Optional. Override the WS tunnel host when it lives on a different domain
# than the API.
# CONTROLLER_WS_URL=wss://your-controller-tunnel.example.com

# Shared secret with the controller's TUNNEL_AUTH_TOKEN. Generate:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
TUNNEL_AUTH_TOKEN=

# Inspector UI port. Default would clash with the customer connector at 9090,
# so this shim defaults to 9091. Set to 0 to disable.
INSPECTOR_PORT=9091

# Optional. Base port for Type 1 auto-allocation (default 7100). Bump this if
# you're running the customer connector and this shim on the same host so
# their auto-port probes don't collide.
# MCP_BASE_PORT=7200
