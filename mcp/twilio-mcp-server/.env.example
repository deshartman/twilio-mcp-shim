# Per-MCP env for the Twilio MCP server. The connector loads this file into
# this child's environment only — it does not leak into other MCPs. Copy
# to .env (gitignored) and fill in.

# Twilio API creds. Twilio Console > Account Info has these.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Phone number used as the From for send_sms. Must be a number you own.
TWILIO_FROM=
